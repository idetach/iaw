# Cloud Run backend environment example
GCS_BUCKET=your_gcs_bucket
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

VISION_PROVIDER=gemini
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

CLAUDE_MODEL_PASS1=claude-opus-4-6
CLAUDE_MODEL_PASS2=claude-opus-4-6
CLAUDE_MODEL_FALLBACKS=claude-opus-4-5,claude-opus-4-1,claude-opus-4,claude-sonnet-4-20250514,claude-3-7-sonnet-20250219,claude-3-5-sonnet-20241022,claude-3-5-sonnet-20240620,claude-3-haiku-20240307
OPENAI_MODEL_PASS1=gpt-5.2-chat-latest
OPENAI_MODEL_PASS2=gpt-5.2
OPENAI_MODEL_FALLBACKS=gpt-5.1,gpt-4.1
GEMINI_MODEL_PASS1=gemini-3.1-pro
GEMINI_MODEL_PASS2=gemini-3.1-pro
GEMINI_MODEL_FALLBACKS=gemini-2.5-pro,gemini-2.5-flash

CASES_PREFIX=cases
SIGNED_URL_TTL_SECONDS=900
MAX_LEVERAGE=50
MAX_MARGIN_PERCENT=25
LIQUIDATION_HEATMAP_TIME_HORIZON_HOURS=24

FRONTEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CAPTURE_WORKER_URL=http://127.0.0.1:8090/trigger-capture
CAPTURE_WORKER_TOKEN=change-me
CAPTURE_WORKER_TIMEOUT_SECONDS=300

GENERATION_STALE_MINUTES=20