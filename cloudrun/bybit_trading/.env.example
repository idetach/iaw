# Bybit API credentials
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Set to "true" to use Bybit testnet
BYBIT_TESTNET=false

# Bearer token for bybit_trading (for agent_trading - buybit_trading auth)
BYBIT_TRADING_TOKEN=your_bybit_trading_token_here

# Futures category: linear (USDT-margined) or inverse
BYBIT_CATEGORY=linear

# CORS origins allowed to call this service (comma-separated)
FRONTEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Radar thresholds
# Minimum absolute price change % to flag as an extreme price event
RADAR_PRICE_CHANGE_PCT_THRESHOLD=3.0
# Minimum 24h volume (in quote currency) to flag as extreme volume event
RADAR_VOLUME_THRESHOLD_USDT=50000000
# Funding rate below this value (negative) is flagged as extreme negative
RADAR_FUNDING_RATE_THRESHOLD=-0.0005

# Port (used by start.sh / run_local.sh)
PORT=8081
