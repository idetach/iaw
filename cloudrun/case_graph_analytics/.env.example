# Neo4j
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# GCS source of truth
GCS_BUCKET=your-bucket
CASES_PREFIX=cases

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
OPENAI_API_KEY=

# Ingestion
INGEST_BATCH_SIZE=200
INGEST_POLL_INTERVAL_SECONDS=30
INGEST_ONCE=true
