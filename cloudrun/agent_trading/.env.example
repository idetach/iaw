# GCS — same bucket/prefix as agent_charts_signal
GCS_BUCKET=iaw_charts
CASES_PREFIX=cases

# Google credentials (leave empty on Cloud Run — uses ADC)
GOOGLE_APPLICATION_CREDENTIALS=

# URL of the bybit_trading service
BYBIT_TRADING_URL=http://localhost:8081

# Bearer token for bybit_trading (for agent_trading - buybit_trading auth)
BYBIT_TRADING_TOKEN=your_bybit_trading_token_here

# CORS origins (comma-separated)
FRONTEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Request timeout to bybit_trading in seconds
BYBIT_TRADING_TIMEOUT=30.0

# Port
PORT=8082
