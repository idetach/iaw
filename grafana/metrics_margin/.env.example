POSTGRES_DB=metrics_margin
POSTGRES_USER=metrics_margin
POSTGRES_PASSWORD=metrics_margin
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin





# Leave empty to auto-discover all USDT margin pairs from Binance.
# Set to a comma-separated list to track only specific pairs.
TRACKED_ASSETS=
TRACKED_SYMBOLS=

PRICE_POLL_SECONDS=300
INVENTORY_POLL_SECONDS=900
CONFIG_POLL_SECONDS=3600
BACKFILL_HOURS=168
PRICE_KLINE_INTERVAL=5m
REQUEST_TIMEOUT_SECONDS=20
MAX_RETRIES=4
RETRY_BACKOFF_SECONDS=1.5
LOG_LEVEL=INFO
APP_NAME=metrics_margin



